# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored and must never be committed.

# Absolute path on the HOST machine to the directory containing data.tsv and citations.tsv
PROTEOMESCOUT_DATA_HOST_DIR=/absolute/path/to/ProteomeScout_Dataset

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret
